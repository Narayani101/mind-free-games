# Local dev: leave unset — Vite proxies /api to the server (vite.config.ts).
# Production (GitHub Pages + Render): GitHub Actions defaults to https://mind-free-games.onrender.com
# Local override: VITE_API_ORIGIN=https://mind-free-games.onrender.com

# If the site is not at the domain root (e.g. https://user.github.io/repo-name/),
# set the path prefix Vite uses for assets and router (leading slash, trailing slash).
# GitHub Actions default for this repo is /mind-free-games/ unless you set repo Variable VITE_BASE_PATH.
# VITE_BASE_PATH=/repo-name/
